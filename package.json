{
  "name": "idaas-ts-sdk-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Identity as a Service TypeScript SDK Generator",
  "license": "ISC",
  "author": "Andrew MacCuaig <andrewmaccuaig@gmail.com>",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun --filter=\"@maccuaa/intellitrust-*-sdk\" run build",
    "clean": "bun ./bin/clean",
    "download": "bun ./bin/download",
    "generate": "bun ./bin/generate",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:workspaces": "bun --filter=\"@maccuaa/intellitrust-*-sdk\" run lint",
    "pack": "bun --filter=\"@maccuaa/intellitrust-*-sdk\" run pack",
    "publish": "bun --filter=\"@maccuaa/intellitrust-*-sdk\" run publish",
    "test": "bun test tests/",
    "test:workspaces": "bun --filter=\"@maccuaa/intellitrust-*-sdk\" run test",
    "typecheck": "bun --filter=\"@maccuaa/intellitrust-*-sdk\" run typecheck",
    "update": "OPENAPI_GENERATOR_CLI_SEARCH_URL=DEFAULT openapi-generator-cli version-manager set latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.4",
    "@openapitools/openapi-generator-cli": "^2.16.3",
    "@types/bun": "^1.2.0"
  },
  "engines": {
    "node": ">= 22.12.0"
  }
}
